# ============================================
# Backend (Laravel) — Production Environment
# Copy to /opt/dukkan/backend_dukkan/.env
# ============================================

APP_NAME=Dukkan
APP_ENV=production
APP_DEBUG=false
APP_URL=https://dukkan-api.haritna.net
APP_KEY=
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# === Logging ===
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# === Database (Neon PostgreSQL) ===
DB_CONNECTION=pgsql
DB_HOST=
DB_PORT=5432
DB_DATABASE=neondb
DB_USERNAME=neondb_owner
DB_PASSWORD=
DB_SSLMODE=require
TENANCY_DATABASE_PREFIX=tenant_

# === Session ===
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# === Broadcasting ===
BROADCAST_CONNECTION=log

# === Storage (Cloudflare R2) ===
FILESYSTEM_DISK=r2
MEDIA_DISK=r2
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=
R2_URL=https://dukkan-media.haritna.net

# === Queue & Cache ===
QUEUE_CONNECTION=redis
CACHE_STORE=redis

# === Redis ===
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

# === Mail ===
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_FROM_ADDRESS="hello@dukkan.haritna.net"
MAIL_FROM_NAME="${APP_NAME}"

# === External Services ===
PHONE_MESSAGE_URL=
PHONE_MESSAGE_API_KEY=
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
ELEVENLABS_URL=
ELEVENLABS_API_KEY=

VITE_APP_NAME="${APP_NAME}"
