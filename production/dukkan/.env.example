# ============================================
# Dukkan Production Environment
# Copy to /opt/dukkan/.env and fill in secrets
# ============================================

# === App ===
APP_NAME=Dukkan
APP_ENV=production
APP_DEBUG=false
APP_URL=https://dukkan-api.haritna.net
APP_KEY=

# === Database (Neon PostgreSQL) ===
DB_CONNECTION=pgsql
DB_HOST=
DB_PORT=5432
DB_DATABASE=neondb
DB_USERNAME=neondb_owner
DB_PASSWORD=
DB_SSLMODE=require
TENANCY_DATABASE_PREFIX=tenant_

# === Redis ===
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

# === Storage (Cloudflare R2) ===
FILESYSTEM_DISK=r2
MEDIA_DISK=r2
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=
R2_URL=https://dukkan-media.haritna.net

# === Frontend (Bun SSR) ===
PORT=3000
API_BASE_URL=http://nginx
VITE_API_BASE_URL=https://dukkan-api.haritna.net

# === Cloudflare (for Let's Encrypt DNS challenge) ===
CF_API_TOKEN=

# === External Services ===
PHONE_MESSAGE_URL=
PHONE_MESSAGE_API_KEY=
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
ELEVENLABS_URL=
ELEVENLABS_API_KEY=

# === Logging ===
LOG_CHANNEL=stack
LOG_LEVEL=warning
LOG_SLACK_WEBHOOK_URL=
